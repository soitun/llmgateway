{
	"name": "docs",
	"version": "0.0.0",
	"private": true,
	"license": "SEE LICENSE IN ../../LICENSE",
	"files": [
		".source",
		".next",
		"out",
		"openapi.json"
	],
	"scripts": {
		"build": "pnpm gen-docs && fumadocs-mdx && next build && cp ./openapi.json ./.next/standalone/apps/docs/ && mkdir -p .next/static && cp -r .next/static .next/standalone/apps/docs/.next/ && test -d public && cp -r public .next/standalone/apps/docs/",
		"dev": "next dev --turbo --port 3005",
		"format": "eslint --fix . && prettier --write .",
		"gen-docs": "node scripts/generate-docs.mjs",
		"generate": "pnpm gen-docs",
		"postinstall": "fumadocs-mdx || true",
		"lint": "eslint . && prettier --check .",
		"start": "next start -H 0.0.0.0"
	},
	"dependencies": {
		"@ai-sdk/react": "3.0.29",
		"@llmgateway/ai-sdk-provider": "3.8.0",
		"@radix-ui/react-presence": "1.1.5",
		"ai": "6.0.27",
		"babel-plugin-react-compiler": "1.0.0",
		"class-variance-authority": "^0.7.1",
		"flexsearch": "^0.8.212",
		"fumadocs-core": "16.9.3",
		"fumadocs-mdx": "15.0.10",
		"fumadocs-openapi": "10.9.1",
		"fumadocs-ui": "16.9.3",
		"gateway": "workspace:*",
		"hast-util-to-jsx-runtime": "2.3.6",
		"lucide-react": "^0.544.0",
		"next": "16.2.7",
		"posthog-js": "1.372.1",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"remark": "15.0.1",
		"remark-gfm": "4.0.1",
		"remark-mdx": "3.1.1",
		"remark-rehype": "11.1.2",
		"shiki": "3.15.0",
		"tailwind-merge": "^3.3.1",
		"unist-util-visit": "5.1.0",
		"zod": "3.25.76"
	},
	"devDependencies": {
		"@tailwindcss/postcss": "^4.2.0",
		"@types/hast": "^3.0.4",
		"@types/mdx": "^2.0.13",
		"@types/react": "^19.2.16",
		"@types/react-dom": "^19.2.3",
		"postcss": "^8.5.10",
		"rimraf": "6.1.3",
		"tailwindcss": "^4.2.0"
	}
}
